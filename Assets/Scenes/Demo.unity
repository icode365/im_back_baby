  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialHandler
  tutorials:
  - '"You are an Alchemist.\n\nNot a follower of instructions.\nA seeker of truth
    beneath symbols."'
  - '"You observe.\nYou test.\nYou learn."'
  - '"Each ingredient holds a nature.\nHeat. Decay. Motion. Binding."'
  - '"Place two or three ingredients into the vessel.\n\nOrder does not matter."'
  - '"The recipe will speak in riddles, so that these doesn''t land in some amataur''s
    hands."'
  - "When your mind is steady & all slots are filled \u2014\\n\\nPress \u201CBrew.\u201D
    to start mixing"
  - '"The vessel will answer. Reveal the hidden reaction. '
  - Proceed wisely.
  tutorialsText: {fileID: 787352817}
  tutorialCanvasGroup: {fileID: 1413506278}
  puzzlePanelEventHandler: {fileID: 2000460043}
